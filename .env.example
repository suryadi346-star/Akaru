# .env.example — Copy ke .env dan isi API key sesuai provider yang dipakai
# Tidak perlu isi semua, cukup yang sesuai provider di config.yml

# ─── GEMINI (Google AI Studio — ada free tier) ─────────
GEMINI_API_KEY=

# ─── ANTHROPIC CLAUDE ──────────────────────────────────
ANTHROPIC_API_KEY=

# ─── OPENAI ────────────────────────────────────────────
OPENAI_API_KEY=

# ─── GROQ (Free tier tersedia) ─────────────────────────
GROQ_API_KEY=

# ─── QWEN (DashScope — ada free tier) ──────────────────
QWEN_API_KEY=

# ─── UNIVERSAL FALLBACK (opsional) ─────────────────────
# Kalau env var spesifik provider tidak di-set, Akaru fallback ke ini
AKARU_API_KEY=

# NOTE: Ollama tidak butuh API key (local)
